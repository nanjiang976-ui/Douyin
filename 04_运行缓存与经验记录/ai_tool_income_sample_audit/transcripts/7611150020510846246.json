    {
      "start": 117.08,
      "end": 120.08,
      "text": "那通人工职能研究院研究的是空间制"
    },
    {
      "start": 120.08,
      "end": 121.76,
      "text": "但是通人工职能研究院"
    },
    {
      "start": 121.76,
      "end": 123.52,
      "text": "几十个上百个工程师"
    },
    {
      "start": 123.52,
      "end": 125.6,
      "text": "每个工程师都负责自己的一块"
    },
    {
      "start": 125.6,
      "end": 126.4,
      "text": "他们讲说"
    },
    {
      "start": 126.4,
      "end": 128.48,
      "text": "在AI你根本就拼挫不到一起去"
    },
    {
      "start": 128.48,
      "end": 130.48,
      "text": "其实研究的时候没有人能够对AI"
