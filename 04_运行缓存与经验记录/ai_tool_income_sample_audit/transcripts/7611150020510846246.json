    {
      "start": 158.52,
      "end": 160.16,
      "text": "马上给你挣大钱"
    },
    {
      "start": 160.16,
      "end": 161.36,
      "text": "你需要的是什么"
    },
    {
      "start": 161.36,
      "end": 163.6,
      "text": "是把它当作一师有的好朋友"
    },
    {
      "start": 163.6,
      "end": 166.64,
      "text": "把它当作你的好导师"
    },
    {
      "start": 166.64,
      "end": 168.16,
      "text": "让她教会你什么"
    },
    {
      "start": 168.16,
      "end": 169.84,
